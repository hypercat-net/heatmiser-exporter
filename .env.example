# Copy to .env and fill in values:
#   cp .env.example .env
#
# The exporter loads .env automatically (existing environment variables win).
# Docker Compose uses env_file: .env — do not commit real tokens.

# Required
NEOHUB_HOST=192.168.0.19
NEOHUB_TOKEN=your-api-token

# Optional NeoHub settings
# NEOHUB_PORT=4243
# NEOHUB_TIMEOUT=15.0

# Optional exporter HTTP bind
# EXPORTER_LISTEN_ADDRESS=0.0.0.0
# EXPORTER_PORT=9780
